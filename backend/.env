# Server Configuration
PORT=8080
ENV=development # change to production for deployment

# Database (Supabase Postgres)
DB_HOST=your-project-id.supabase.co
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=postgres
DB_PORT=5432
DATABASE_URL=postgresql://postgres:password@db.host:5432/postgres

# Authentication
JWT_SECRET=generate-a-very-long-random-string
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
MONTHLY_PLAN_ID=price_...
YEARLY_PLAN_ID=price_...

# Charity Logic
MIN_CHARITY_PERCENT=10

# Email (Resend or Postmark)
EMAIL_API_KEY=your-api-key
EMAIL_FROM=notifications@impact5.com
